<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CalorieCalculatorApp.FoodPage">

    <StackPanel Margin="20" Spacing="15">

        <TextBlock Text="База продуктів" Classes="pageTitle"/>
        <TextBlock Text="Список продуктів з калорійністю" Classes="pageSubtitle"/>

        <Border Height="1" Background="#DDDDDD" Margin="0,5,0,5"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     PlaceholderText="Пошук продукту..."
                     Classes="input"
                     Margin="0,0,10,0"/>
            <Button Grid.Column="1"
                    Content="+ Додати продукт"
                    Classes="primary"/>
        </Grid>

        <Border Background="#F5F5F5" Padding="15">
            <StackPanel Spacing="10">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Назва" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="Калорії/100г" FontWeight="Bold"/>
                    <TextBlock Grid.Column="2" Text="Білки" FontWeight="Bold"/>
                    <TextBlock Grid.Column="3" Text="Жири" FontWeight="Bold"/>
                </Grid>

                <Border Height="1" Background="#DDDDDD"/>

                <TextBlock Text="Продуктів поки немає. Натисніть + Додати продукт"
                           Foreground="#AAA"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>

            </StackPanel>
        </Border>

    </StackPanel>

</UserControl>
