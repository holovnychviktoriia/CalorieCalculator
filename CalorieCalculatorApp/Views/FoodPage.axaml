<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CalorieCalculatorApp.FoodPage">

    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="15">

        <TextBlock Text="База продуктів"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   HorizontalAlignment="Center"/>

        <TextBlock Text="Тут буде список продуктів з калорійністю."
                   FontSize="16"
                   Foreground="#555"
                   HorizontalAlignment="Center"/>

    </StackPanel>

</UserControl>