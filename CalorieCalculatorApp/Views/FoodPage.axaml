<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:CalorieCalculatorApp.Models"
             xmlns:local="clr-namespace:CalorieCalculatorApp"
             x:Class="CalorieCalculatorApp.FoodPage"
             x:DataType="local:FoodPage">

    <StackPanel Margin="20" Spacing="15">

        <TextBlock Text="База продуктів" Classes="pageTitle"/>
        <TextBlock Text="Список продуктів з калорійністю" Classes="pageSubtitle"/>

        <Border Height="1" Background="#DDDDDD" Margin="0,5,0,5"/>

        <Border Background="#F5F5F5" Padding="15">
            <StackPanel Spacing="10">
                <TextBlock Text="Додати новий продукт" FontWeight="Bold"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Name="InputProductName"
                             PlaceholderText="Назва продукту..."
                             Background="White"
                             Margin="0,0,10,0"/>

                    <TextBox Grid.Column="1"
                             Name="InputProductCalories"
                             PlaceholderText="Калорій на 100г..."
                             Background="White"
                             Margin="0,0,10,0"/>

                    <Button Grid.Column="2"
                            Content="+ Додати"
                            Classes="primary"
                            Click="BtnAddProduct_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border Background="#F5F5F5" Padding="15">
            <StackPanel Spacing="10">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Назва" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="Калорії/100г" FontWeight="Bold"/>
                </Grid>

                <Border Height="1" Background="#DDDDDD"/>

                <ItemsControl ItemsSource="{Binding Products}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="models:Product">
                            <Grid Margin="0,5,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Name}"/>
                                <TextBlock Grid.Column="1" Text="{Binding CaloriesPer100g}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </Border>

    </StackPanel>

</UserControl>
