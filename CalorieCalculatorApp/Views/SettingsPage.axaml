<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:CalorieCalculatorApp.Models"
             x:Class="CalorieCalculatorApp.SettingsPage"
             x:DataType="models:UserSettings">

    <StackPanel Margin="20" Spacing="15">

        <TextBlock Text="Налаштування" Classes="pageTitle"/>
        <TextBlock Text="Введіть свої дані для розрахунку норми калорій" Classes="pageSubtitle"/>

        <Border Height="1" Background="#DDDDDD" Margin="0,5,0,5"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Ім'я:"
                       VerticalAlignment="Center" Margin="0,0,0,12"/>
            <TextBox Grid.Row="0" Grid.Column="1"
                     Text="{Binding Name, Mode=TwoWay}"
                     PlaceholderText="Введіть ім'я..."
                     Background="#EEEEEE"
                     Margin="0,0,0,12"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Вік:"
                       VerticalAlignment="Center" Margin="0,0,0,12"/>
            <TextBox Grid.Row="1" Grid.Column="1"
                     Text="{Binding Age, Mode=TwoWay}"
                     PlaceholderText="Введіть вік..."
                     Background="#EEEEEE"
                     Margin="0,0,0,12"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Вага (кг):"
                       VerticalAlignment="Center" Margin="0,0,0,12"/>
            <TextBox Grid.Row="2" Grid.Column="1"
                     Text="{Binding Weight, Mode=TwoWay}"
                     PlaceholderText="Введіть вагу..."
                     Background="#EEEEEE"
                     Margin="0,0,0,12"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Зріст (см):"
                       VerticalAlignment="Center" Margin="0,0,0,12"/>
            <TextBox Grid.Row="3" Grid.Column="1"
                     Text="{Binding Height, Mode=TwoWay}"
                     PlaceholderText="Введіть зріст..."
                     Background="#EEEEEE"
                     Margin="0,0,0,12"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Стать:"
                       VerticalAlignment="Center" Margin="0,0,0,12"/>
            <StackPanel Grid.Row="4" Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="15" Margin="0,0,0,12">
                <RadioButton Name="RadioFemale" Content="Жінка" IsChecked="True"/>
                <RadioButton Name="RadioMale" Content="Чоловік"/>
            </StackPanel>

            <Button Grid.Row="5" Grid.Column="1"
                    Content="Зберегти та розрахувати норму"
                    Classes="primary"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,12"
                    Click="BtnSave_Click"/>

            <TextBlock Grid.Row="6" Grid.Column="1"
                       Text="{Binding DailyCalorieGoal, StringFormat='Ваша денна норма: {0} ккал'}"
                       FontWeight="Bold"
                       Foreground="#2C3E50"
                       FontSize="16"
                       Margin="0,0,0,8"/>

            <TextBlock Grid.Row="7" Grid.Column="1"
                       Text="{Binding ErrorMessage}"
                       Foreground="Red"
                       FontSize="13"/>

        </Grid>

    </StackPanel>

</UserControl>
