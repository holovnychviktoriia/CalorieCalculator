<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CalorieCalculatorApp.HomePage">

    <StackPanel Margin="20" Spacing="15">

        <TextBlock Text="Головна" Classes="pageTitle"/>
        <TextBlock Text="Ваш денний прогрес харчування" Classes="pageSubtitle"/>

        <Border Height="1" Background="#DDDDDD" Margin="0,5,0,5"/>

        <StackPanel Spacing="10">

            <Border Background="#F5F5F5" Padding="15">
                <StackPanel>
                    <TextBlock Text="З'їдено" Foreground="#555" FontSize="13"/>
                    <TextBlock Text="0 ккал" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="#F5F5F5" Padding="15">
                <StackPanel>
                    <TextBlock Text="Денна норма" Foreground="#555" FontSize="13"/>
                    <TextBlock Text="2000 ккал" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="#F5F5F5" Padding="15">
                <StackPanel>
                    <TextBlock Text="Залишилось" Foreground="#555" FontSize="13"/>
                    <TextBlock Text="2000 ккал" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
            </Border>

        </StackPanel>

    </StackPanel>

</UserControl>
